# Copy this file to .env and fill in your DeepSeek API key.
DEEPSEEK_API_KEY=

# Optional: Feishu custom bot webhook.
FEISHU_WEBHOOK=

# Public report address, for example https://your-project.pages.dev
REPORT_BASE_URL=

# Optional: use another profile file. Defaults to profile.yaml.
# PROFILE_PATH=profile.yaml

# Optional: override the DeepSeek Anthropic-compatible endpoint.
# DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
